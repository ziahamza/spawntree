{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "dist",
    "plugins": [{ "name": "@effect/language-service" }],
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
